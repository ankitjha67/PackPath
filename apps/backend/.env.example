ENVIRONMENT=local
DEBUG=true

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Postgres
DATABASE_URL=postgresql+asyncpg://packpath:packpath@localhost:5432/packpath

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-in-prod-use-openssl-rand-hex-32
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# OTP
OTP_TTL_SECONDS=300
OTP_LENGTH=6
# When MSG91_AUTH_KEY is empty, OTP is returned in the API response (dev only).
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=PACKPT

# Maps providers — pick a default + optional fallback chain.
# MAPS_PROVIDER: mapbox | google | mappls | here | tomtom | osrm
# MAPS_FALLBACK_PROVIDERS: comma-separated list, tried in order on failure
MAPS_PROVIDER=
MAPS_FALLBACK_PROVIDERS=

# Mapbox
MAPBOX_SERVER_TOKEN=

# Google Maps Platform — needs Directions API enabled
GOOGLE_MAPS_API_KEY=

# Mappls (formerly MapmyIndia) — OAuth client credentials + optional REST key
MAPPLS_CLIENT_ID=
MAPPLS_CLIENT_SECRET=
MAPPLS_REST_KEY=

# HERE Maps — apikey from developer.here.com
HERE_API_KEY=

# TomTom — apikey from developer.tomtom.com
TOMTOM_API_KEY=

# OSRM — defaults to the public demo, override with self-hosted URL
OSRM_BASE_URL=https://router.project-osrm.org

# LiveKit (PTT)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# FCM
FCM_SERVICE_ACCOUNT_JSON=
